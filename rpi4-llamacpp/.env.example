# llama-server RPi 4 configuration
# Copy to .env and edit as needed

# -- Model config --
# Swap models by changing these two lines
MODEL_URL=https://huggingface.co/bartowski/Qwen_Qwen3-4B-GGUF/resolve/main/Qwen_Qwen3-4B-Q4_K_M.gguf
MODEL_FILENAME=Qwen3-4B-Q4_K_M.gguf
# Other options:
#   Granite 4.1 3B (smaller, weaker tool calling):
#     MODEL_URL=https://huggingface.co/bartowski/ibm-granite_granite-4.1-3b-GGUF/resolve/main/ibm-granite_granite-4.1-3b-Q4_K_M.gguf
#     MODEL_FILENAME=granite-4.1-3b-Q4_K_M.gguf
#   Qwen3 1.7B (lightest, for 4GB Pi under pressure):
#     MODEL_URL=https://huggingface.co/bartowski/Qwen_Qwen3-1.7B-GGUF/resolve/main/Qwen_Qwen3-1.7B-Q4_K_M.gguf
#     MODEL_FILENAME=Qwen3-1.7B-Q4_K_M.gguf

# Server port (exposed on LAN)
PORT=8080

# CPU threads (Pi 4 has 4 cores)
THREADS=4

# Context window size (tokens). Lower = less RAM.
# 4096 is safe on 8GB Pi 4. Try 2048 on 4GB.
CTX_SIZE=2048

# KV cache quantization — big RAM savings on Pi 4
# Options: f16 (default/best quality), q8_0, q4_0
# q8_0/q4_0 cuts KV cache ~60% with minimal quality loss
KV_CACHE_K=q8_0
KV_CACHE_V=q4_0

# Memory limit for the container
# 8GB Pi: 6g or 7g  |  4GB Pi: 3g
MEM_LIMIT=3g

# Extra llama-server flags (optional)
# e.g. "--log-disable" or "--metrics"
EXTRA_ARGS=--parallel 1 --repeat-penalty 1.1 --api-key your-secret-key-here
